{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "codex-cloud-console",
  "main": "worker.js",
  "compatibility_date": "2026-05-23",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "routes": [
    {
      "pattern": "codex.woai.pro",
      "custom_domain": true
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "codex-cloud-console",
      "database_id": "4f8b6608-4423-4976-93d3-0f16d677fda2"
    }
  ]
}
